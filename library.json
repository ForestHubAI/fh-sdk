{
    "name": "fh-sdk",
    "version": "0.1.0",
    "description": "C++14 LLM proxy library with unified interface for multiple providers. Platform-agnostic via Hardware Abstraction Layer.",
    "keywords": "llm, ai, foresthub, arduino, embedded, esp32, agent, rag",
    "repository": {
        "type": "git",
        "url": "https://github.com/ForestHubAI/fh-sdk"
    },
    "license": "MIT",
    "frameworks": "arduino",
    "platforms": "*",
    "build": {
        "srcDir": "src",
        "includeDir": "include",
        "flags": [
            "-DFORESTHUB_PLATFORM_ARDUINO",
            "-DJSON_HAS_CPP_14",
            "-Os",
            "-ffunction-sections",
            "-fdata-sections",
            "-Ithird_party",
            "-Isrc"
        ],
        "srcFilter": [
            "+<*>",
            "+<rag/>",
            "-<platform/pc/>",
            "-<platform/pc/*>"
        ]
    },
    "dependencies": [
        {
            "name": "ArduinoHttpClient",
            "owner": "arduino-libraries",
            "version": ">=0.6.1",
            "frameworks": "arduino"
        }
    ],
    "export": {
        "exclude": [
            "build",
            "examples",
            "pio",
            "tests",
            ".git",
            ".gitignore",
            "CMakeLists.txt",
            "run_coverage.sh"
        ]
    }
}
