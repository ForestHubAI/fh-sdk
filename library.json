{
    "name": "fh-sdk",
    "version": "0.1.0",
    "description": "C++14 LLM SDK with unified interface for ForestHub, OpenAI, Gemini, and Anthropic. Agent framework with tool-calling, RAG, and multi-turn conversations. Platform-agnostic via HAL — targets PC and embedded (Arduino/ESP32/Portenta).",
    "keywords": "llm, ai, foresthub, arduino, embedded, esp32, agent, rag, tool-calling, multi-provider, c++14, portenta, openai, gemini, anthropic",
    "authors": [
        {
            "name": "ForestHub AI",
            "url": "https://github.com/ForestHubAI"
        }
    ],
    "homepage": "https://github.com/ForestHubAI/fh-sdk",
    "repository": {
        "type": "git",
        "url": "https://github.com/ForestHubAI/fh-sdk"
    },
    "license": "AGPL-3.0-only",
    "frameworks": "arduino",
    "platforms": "*",
    "build": {
        "srcDir": "src",
        "includeDir": "include",
        "flags": [
            "-DFORESTHUB_PLATFORM_ARDUINO",
            "-DJSON_HAS_CPP_14",
            "-Os",
            "-ffunction-sections",
            "-fdata-sections",
            "-Ithird_party",
            "-Isrc"
        ],
        "srcFilter": [
            "+<*>",
            "+<rag/>",
            "-<platform/pc/>",
            "-<platform/pc/*>"
        ]
    },
    "dependencies": [
        {
            "name": "ArduinoHttpClient",
            "owner": "arduino-libraries",
            "version": ">=0.6.1",
            "frameworks": "arduino"
        }
    ],
    "export": {
        "include": [
            "include",
            "src",
            "third_party",
            "LICENSE",
            "THIRD_PARTY_NOTICES"
        ]
    }
}
